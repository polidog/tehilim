{
    "name": "polidog/tehilim",
    "description": "Prisma-style schema-first database toolkit for PHP. No class mapping; generated query clients with PHPStan-friendly array shapes.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "ext-pdo": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Polidog\\Tehilim\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Polidog\\Tehilim\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/tehilim"],
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    }
}
