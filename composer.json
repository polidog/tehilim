{
    "name": "polidog/tehilim",
    "description": "Prisma-style schema-first database toolkit for PHP. No class mapping; generated query clients with PHPStan-friendly array shapes.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Polidog\\Tehilim\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Polidog\\Tehilim\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/tehilim"],
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse"
    },
    "config": {
        "sort-packages": true
    }
}
